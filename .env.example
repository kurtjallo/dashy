# Copy to .env for local development (docker-compose supplies postgres/redis)
DATABASE_URL=postgres://dashy:dashy@localhost:5432/dashy
REDIS_URL=redis://localhost:6379
# Both must be at least 32 characters. For real keys: `openssl rand -base64 32`
SESSION_SECRET=dev-only-session-secret-change-me-before-prod
ENCRYPTION_KEY=dev-only-encryption-key-change-me-before-prod
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
NODE_ENV=development
API_BASE_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
SENTRY_DSN=
