{
  "name": "@dashy/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "migrate": "dotenv -e ../../.env -- node-pg-migrate up -m migrations -j sql",
    "migrate:down": "dotenv -e ../../.env -- node-pg-migrate down -m migrations -j sql",
    "migrate:create": "node-pg-migrate create -m migrations -j sql"
  },
  "dependencies": {
    "@dashy/shared": "workspace:*",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "bullmq": "^5.30.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "ioredis": "5.10.1",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "ulid": "^3.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "dotenv-cli": "^8.0.0",
    "node-pg-migrate": "^7.8.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
